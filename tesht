#!/usr/bin/env bash

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Private function names begin with lowercase letters.
# Public function names begin with uppercase letters.
# Function names are prefixed with "tesht." (always lowercase) so they are namespaced.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
#
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
# Global variable names are also namespaced by suffixing them with
# the randomly-generated letter T, e.g. GlobalVariableT.
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".

IFS=$'\n'
NL=$'\n'

Prog=$(basename "$0")   # match what the user called

read -rd '' Usage_ <<END
Usage:

  $Prog [OPTIONS] [--] [FILE...]

  Options:

    -run REGEXP         filter test names by bash native regex (=~)
                        (equals-syntax variant: -run=REGEXP)
    -h | --help         show this message and exit
    -x | --trace        enable debug tracing
    --                  stop option processing

  Arguments:

    FILE...             run tests from the specified file(s) or directories
                        (directories expand to *_test.bash, one level deep)
                        (if none given, runs all *_test.bash files in cwd)

  Examples:

    $Prog                              # run all tests in all *_test.bash files
    $Prog my_test.bash                 # run tests in one file
    $Prog foo_test.bash bar_test.bash  # multiple files
    $Prog scripts/                     # all *_test.bash in scripts/ (shallow)
    $Prog -run TestMyFunction          # filter by name regex (any file)
    $Prog my_test.bash -run TestFoo    # file + name filter
    $Prog -run=TestFoo my_test.bash    # equals-syntax variant

  Matches Go's go-test convention: positional args are files; -run
  REGEXP filters test names. Empty regex matches all tests.
END

GreenT=$'\033[38;5;82m'
RedT=$'\033[38;5;196m'
YellowT=$'\033[38;5;220m'

ResetT=$'\033[0m'

FailT=${RedT}FAIL$ResetT
FatalT=${RedT}FATAL$ResetT
PassT=${GreenT}PASS$ResetT
RunT=${YellowT}RUN$ResetT

UnixMilliFuncT=tesht.UnixMilli

# tesht.Main runs any test functions in the files given as arguments.
# It outputs success or failure.
#
# Args: $1 = test-name regex filter (empty = match all);
#       $2 = newline-separated list of test files (typically built via tesht.ListOf).
tesht.Main() {
  local runRegexp=${1:-} filenames=( ${2:-} )

  local -i PassCountT=0 TestCountT=0 failed=0   # -i enables arithmetic operations
  local startTime=$($UnixMilliFuncT)

  for filename in "${filenames[@]}"; do
    tesht.testFile $filename "$runRegexp" || failed=1
  done

  (( TestCountT > 0 )) || failed=2

  local endTime=$($UnixMilliFuncT)
  local duration=$(( endTime - startTime ))ms

  local columns='%s\t\t%s\n'
  (( failed )) && local result=$FailT || local result=$PassT
  printf $columns $result $duration

  echo $PassCountT/$TestCountT
  return $failed
}

# tesht.failFlag signals a mid-body assertion failure to the test runner
# (#25287). Bash suppresses set -e inside functions invoked from && || compound
# lists, so a returning rc=0 from the function's last command would silently
# pass when an earlier assertion failed. Helpers call this to raise a sentinel
# the runner checks after the test/subtest body returns.
#
# The PID gate (BASHPID == TESHT_FAIL_FLAG_PID) scopes the flag to the
# test/subtest's own subshell: an assertion intentionally exercised inside a
# nested $(...) or (...) -- e.g. helper self-tests that capture the helper's
# failure output -- runs at a different BASHPID and does not taint the outer
# verdict.
tesht.failFlag() {
  [[ -z ${TESHT_FAIL_FLAG:-} ]] && return
  [[ ${TESHT_FAIL_FLAG_PID:-} == "$BASHPID" ]] || return
  touch "$TESHT_FAIL_FLAG"
}

# tesht.AssertGot returns whether the items match and, if not, outputs a message.
tesht.AssertGot() {
  local got=$1 want=${2:-}

  [[ $got == "$want" ]] && return

  tesht.failFlag

  cat <<END


got does not match want:
$(tesht.Diff "$got" "$want")

use this line to update want to match:
    want=${got@Q}

END

  return 1
}

# tesht.AssertRC compares return codes and reports if they don't match.
tesht.AssertRC() {
  local rc=$1 wantrc=$2

  (( rc == wantrc )) && return
  tesht.failFlag
  tesht.Log "error: rc = $rc, want: $wantrc"
  return 1
}

# tesht.declareVar returns a declaration for a variable, handling arrays if the name is plural.
tesht.declareVar() {
  local name=$1 value=$2
  [[ $name == *s || $name == *s_ && $value == '('*')' ]] &&
    echo "declare -a $name=${value@Q}" ||
    echo "declare $name=${value@Q}"
}

# tesht.Defer schedules a command to run on EXIT, preserving any existing EXIT trap.
tesht.Defer() {
  local command=$1
  local NL=$'\n' # newline works with backgrounding (&) and legal semicolons, semicolon doesn't
  trap "$command$NL$(tesht.existingDeferlist)" EXIT
}

# tesht.Diff returns a diff of its arguments with special characters shown by cat.
# It is a test helper to generate failed assertion output.
tesht.Diff() {
  local got=$1 want=$2
  diff <(echo "$got") <(echo "$want") | cat -vT | tail -n +2
}

# tesht.existingDeferlist returns the current EXIT trap command without the trap wrapper.
tesht.existingDeferlist() {
  local deferlist_=$(trap -p EXIT)
  deferlist_=${deferlist_#trap -- \'}
  deferlist_=${deferlist_%\' EXIT}
  echo "$deferlist_"
}

# tesht.Inherit returns an eval'able set of variable assignments from a map.
# The map is an associative array variable in the outer scope named by mapname.
# It is a test helper that makes it simple to work with the keys of the testmap.
# Inspired by nix's inherit keyword.
tesht.Inherit() {
  local MAPNAME=$1
  local -n MAP=$MAPNAME

  local KEY
  for KEY in ${!MAP[*]}; do
    tesht.declareVar $KEY "${MAP[$KEY]}"
  done
}

# tesht.ListOf joins its arguments with newlines.
tesht.ListOf() {
  local IFS=$'\n'
  echo "$*"
}

# tesht.listTestnames lists the name of any functions in $1.
# Valid function names begin the line with "test_",
# followed by identifier characters and "()".
tesht.listTestnames() {
  awk '/^test_[-_.a-zA-Z0-9]+()/ { sub(/\(.*/, "", $1); print $1 }' $1
}

tesht.Log() {
  local IFS=$NL
  echo "$NL$NL$*"
}

# tesht.MktempDir makes a temporary directory and sets the reference variable to the directory name.
# It returns an error if it cannot make the directory.
tesht.MktempDir() {
  local -n DIR=$1
  DIR=$(mktemp -d /tmp/tesht.XXXXXX) || { echo 'could not create temporary directory'; return 1; }

  [[ $DIR == /*/* ]] || { echo 'temporary directory does not comply with naming requirements'; return 1; }

  [[ -d $DIR ]] || { echo 'temporary directory was made but does not exist now'; return 1; }

  tesht.Defer "tesht.removeWithRetry $DIR"
}

# tesht.removeWithRetry rm -rf's a directory, retrying on ENOTEMPTY/EBUSY for up
# to 5 attempts at 200ms intervals (1s total). After exhausting retries it logs
# a warning and returns 0 so a child process still writing into a test's
# tmpdir at EXIT-trap time does not flip a passing test to FAIL on the cleanup
# seam (#37012; race exposed by agent-orchestration fakebin-golden speedup).
# Test-body assertions are the source of truth; cleanup is best-effort.
tesht.removeWithRetry() {
  local dir=$1
  local -i attempt
  for attempt in 1 2 3 4 5; do
    rm -rf -- "$dir" 2>/dev/null && return 0
    sleep 0.2
  done
  echo "warning: tesht.removeWithRetry: gave up on $dir after 5 attempts; child process may have leaked" >&2
  return 0
}

# tesht.portIsInUse detects whether port is already in use.
tesht.portIsInUse() {
  local pid rc
  command -v lsof &>/dev/null && {
    pid=$(lsof -tiTCP:$port -sTCP:LISTEN) && rc=$? || rc=$?
    (( rc == 0 )) && echo "http server port $port is taken by pid $pid"
    return $rc
  }

  command -v ss &>/dev/null && {
    ss -tuln | grep -q ":$port\b" && rc=$? || rc=$?
    (( rc == 0 )) && echo "http server port $port is taken"
    return $rc
  }

  netstat -an | grep -qE "(:$port\s+).*LISTEN" && rc=$? || rc=$?
  (( rc == 0 )) && echo "http server port $port is taken"
  return $rc
}

# tesht.Run runs tesht.runSubtest on each test case.
tesht.Run() {
  local FAILED=0 CASENAME
  for CASENAME in "$@"; do
    tesht.runSubtest "${FUNCNAME[1]}" "$CASENAME" || {
      (( $? == 128 )) && return 128 # fatal
      FAILED=1
    }
  done

  return $FAILED
}

# tesht.runSubtest runs the function `subtest` with mapname as an argument.
# mapname is the name of an associative array in an outer scope
# holding at least the key "name".
# It outputs success or failure.
# It returns an error result code if there was failure.
# It cannot wholly rely on the global namespace for tesht functions/variables
# because it runs in the context of a test, so be careful.
tesht.runSubtest() {
  local testname=$1 mapname=$2

  local -n map=$mapname
  local testname=$testname/${map[name]}

  local columns='=== %s\t\t\t%s'
  printf $columns $RunT $testname

  local startTime=$($UnixMilliFuncT) rc
  # Reset the per-test fail-flag before each subtest so a prior subtest's
  # assertion failures don't leak into this one (#25287). Set
  # TESHT_FAIL_FLAG_PID to the subtest subshell's BASHPID so helpers called
  # directly inside the subtest body raise the flag, while helpers exercised
  # via nested $(...) (e.g. in helper self-tests) do not.
  [[ -n ${TESHT_FAIL_FLAG:-} ]] && rm -f "$TESHT_FAIL_FLAG"
  ( TESHT_FAIL_FLAG_PID=$BASHPID; subtest $mapname ) && rc=$? || rc=$?
  # Override rc=0 to rc=1 if any assertion helper raised the fail-flag inside
  # the subtest body (set -e is suppressed by the && || invocation shape).
  (( rc == 0 )) && [[ -n ${TESHT_FAIL_FLAG:-} && -e $TESHT_FAIL_FLAG ]] && rc=1
  local endTime=$($UnixMilliFuncT)
  local duration=$(( endTime - startTime ))ms

  subtestTestCount+=1   # in caller's scope
  columns='\r--- %s\t%s\t%s\n'
  case $rc in
    0   )
      printf $columns $PassT $duration $testname
      subtestPassCount+=1   # in caller's scope
      ;;
    128 ) printf $columns $FatalT $duration $YellowT$testname$ResetT;;

    *   ) printf $columns $FailT $duration $YellowT$testname$ResetT;;
  esac

  return $rc
}

# tesht.Smoke runs a command and asserts its exit code matches the expected value.
# Use for ad-hoc CLI smoke checks outside test functions, where naive shell
# chains propagate the last command's exit code -- producing a script-level
# nonzero even when an intentional-failure path was being verified. tesht.Smoke
# inverts that: nonzero from the command is success when expected, and the
# helper returns 0; mismatches return 1 with the actual rc and captured output
# on stderr.
#
# Usage: tesht.Smoke EXPECTED_RC -- CMD [ARGS...]
#        tesht.Smoke EXPECTED_RC CMD [ARGS...]   # -- optional
tesht.Smoke() {
  local want=$1; shift
  [[ ${1:-} == -- ]] && shift
  local got_ rc=0
  got_=$("$@" 2>&1) || rc=$?
  (( rc == want )) && return 0
  tesht.failFlag
  tesht.Log "FAIL: expected rc=$want, got rc=$rc from: $*"
  tesht.Log "  output: $got_"
  return 1
}

# tesht.Softly runs assertions provided on stdin and reports whether any failed.
tesht.Softly() {
  local FAILED=0 LINE  # don't mask higher namespaces
  while IFS='' read -r LINE; do
    eval "$LINE" || FAILED=1
  done
  return $FAILED
}

# tesht.StartHttpServer starts an http server in the current directory on 127.0.0.1:port.
# It waits until the server is ready before returning.
tesht.StartHttpServer() {
  local port=${1:-8000}

  tesht.portIsInUse $port && return 1

  # start the http server, redirect stdout so it doesn't hang
  pid=$(python3 -m http.server $port --bind 127.0.0.1 &>/dev/null & echo $!)
  (( pid != 0 )) || { echo 'could not start http server'; return 1; }

  for duration in 0.1 0.2 0.4 0.8; do
    sleep $duration
    curl http://127.0.0.1:$port &>/dev/null && rc=$? || rc=$?
    (( rc == 0 )) && break
  done

  (( rc == 0 )) && echo $pid || echo 'could not connect to http server'

  return $rc
}

# tesht.test tests the named function.
tesht.test() {
  local testSource_=$1 testname=$2

  local startTime=$($UnixMilliFuncT)

  local tmpname=$(mktemp -u)   # -u doesn't create a file, just a name
  # Per-test fail-flag sentinel (#25287). Assertion helpers touch this file on
  # failure; tesht.test (and tesht.runSubtest for subtests) checks the file
  # after the test body returns to override a misleading rc=0 from set -e
  # being suppressed by the && || invocation shape.
  local failflag=$(mktemp -u /tmp/tesht.failflag.XXXXXX)
  export TESHT_FAIL_FLAG=$failflag
  local -i hasSubtests=0 subtestTestCount=0 subtestPassCount=0
  (
    # Scope fail-flag touches to this test's subshell (#25287). Helpers
    # called inside nested $(...) or (...) subshells (e.g. helper self-tests
    # that capture an intentional assertion failure) run at a different
    # BASHPID and are correctly ignored by the fail-flag mechanism.
    TESHT_FAIL_FLAG_PID=$BASHPID
    eval "$testSource_"

    [[ $(declare -f $testname) == *tesht.Run* ]] && hasSubtests=1

    local columns='=== %s\t\t\t%s'
    (( hasSubtests )) || printf $columns $RunT $testname

    $testname && rc=$? || rc=$?
    # Override rc=0 to rc=1 if an assertion helper raised the fail-flag during
    # the test body. Only relevant for non-subtest tests; tesht.runSubtest
    # handles the flag per-subtest. Subtests' rc is reflected via the outer
    # subtestPassCount aggregation, so the test-level rc here stays as-is.
    (( hasSubtests )) || { (( rc == 0 )) && [[ -e $TESHT_FAIL_FLAG ]] && rc=1; }
    (( hasSubtests )) && echo "$subtestTestCount $subtestPassCount" >$tmpname
    exit $rc
  ) && rc=$? || rc=$?
  rm -f "$failflag"
  unset TESHT_FAIL_FLAG

  [[ -e $tmpname ]] && {
    hasSubtests=1
    IFS=' ' read -r subtestTestCount subtestPassCount <$tmpname
    rm -f $tmpname
  }

  local endTime=$($UnixMilliFuncT)
  local duration=$(( endTime - startTime ))ms

  if (( hasSubtests )); then
    TestCountT+=$subtestTestCount
    PassCountT+=$subtestPassCount

    # Propagate subtest failure to caller's `failed` (#25287). Without this,
    # subtest FAIL markers reach stdout but tesht.Main reports overall PASS
    # and exits 0 — same silent-pass class as the assertion-fail-flag bug.
    (( rc == 128 )) && return 128
    (( rc != 0 )) && failed=1
    return
  else
    TestCountT+=1
  fi

  local columns='\r--- %s\t%s\t%s\n'
  case $rc in
    0 )
      printf $columns $PassT $duration $testname
      PassCountT+=1
      ;;
    128 ) printf $columns $FatalT $duration $testname; return 128;;
    *   ) printf $columns $FailT $duration $YellowT$testname$ResetT; failed=1;;
  esac
}

# tesht.testFile runs any test functions in filename, or just functions whose
# names match runRegexp (bash =~ regex; empty = match all).
# It outputs success or failure.
# It returns an error result code if there was a failure.
#
# Exports TESHT_TEST_FILE (absolute path) so test bodies can locate adjacent
# scripts. Inside the eval'd test source, $BASH_SOURCE refers to the tesht
# binary, not the test file -- see "Script discovery" in docs/tesht.md.
tesht.testFile() {
  local filename=$1 runRegexp=${2:-}

  local failed=0    # overall result -- fails if any individual run fails
  local testsInFile=( $(tesht.listTestnames $filename) )
  local testSource_=$(<$filename)
  export TESHT_TEST_FILE=$(realpath -- "$filename")
  for testname in ${testsInFile[@]}; do
    [[ -z $runRegexp || $testname =~ $runRegexp ]] && tesht.test "$testSource_" $testname
  done

  return $failed
}

# tesht.UnixMilli returns the current time in Unix time as milliseconds.
tesht.UnixMilli() {
  local whole fraction
  # EPOCHREALTIME reports second fractions to nano precision
  IFS=. read -r whole fraction <<<$EPOCHREALTIME
  echo "$whole${fraction:0:3}"
}

# Parse command-line options + positionals. Flags can interleave with positional
# args; the loop classifies each arg per turn. `--` terminates flag parsing
# (everything after is positional, including args that start with `-`).
RunRegexpT=""
FilenamesT=()
while (( $# )); do
  case $1 in
    -h|--help)  echo "$Usage_"; exit;;
    -x|--trace) set -x; shift;;
    -run)       shift; RunRegexpT=${1:?-run requires a regexp}; shift;;
    -run=*)     RunRegexpT=${1#-run=}; shift;;
    --)         shift; FilenamesT+=( "$@" ); break;;
    -*)         echo "error: unknown option: $1" >&2; exit 2;;
    *)          FilenamesT+=( "$1" ); shift;;
  esac
done

# Inverted file-look guard — 4-branch table:
#   directory -> expand to shallow *_test.bash files (branch 1)
#   on-disk file -> accept (branch 2; matches _test.bash or operator named a real file)
#   ends in _test.bash AND not on disk -> file-not-found error (branch 3)
#   anything else -> did-you-mean error (branch 4)
ExpandedFilesT=()
for arg in "${FilenamesT[@]+"${FilenamesT[@]}"}"; do
  if [[ -d $arg ]]; then
    shopt -s nullglob
    dirFilesT=( "$arg"/*_test.bash )
    shopt -u nullglob
    (( ${#dirFilesT[@]} > 0 )) || {
      echo "error: no *_test.bash files in directory: $arg" >&2
      exit 2
    }
    ExpandedFilesT+=( "${dirFilesT[@]}" )
  elif [[ -f $arg ]]; then
    ExpandedFilesT+=( "$arg" )
  elif [[ $arg == *_test.bash ]]; then
    echo "error: file not found: $arg" >&2
    exit 2
  else
    echo "error: '$arg' does not look like a test file or directory; did you mean: $Prog -run $arg, $Prog <dir>, or $Prog <dir>/*_test.bash?" >&2
    exit 2
  fi
done
FilenamesT=( "${ExpandedFilesT[@]+"${ExpandedFilesT[@]}"}" )

# If no files specified, use all test files in cwd.
if (( ${#FilenamesT[@]} == 0 )); then
  shopt -s nullglob
  FilenamesT=( *_test.bash )
  shopt -u nullglob
  (( ${#FilenamesT[@]} == 0 )) && { echo "no test files found"; exit; }
fi

# strict mode
return 2>/dev/null
set -euf

tesht.Main "$RunRegexpT" "$(tesht.ListOf "${FilenamesT[@]}")"
